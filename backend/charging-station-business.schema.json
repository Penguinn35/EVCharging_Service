{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evcharging.local/schemas/charging-station-business.schema.json",
  "title": "Business Charging Station Schemas",
  "description": "Canonical schema set for enterprise charging station data.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "station": {
      "$ref": "#/$defs/BusinessChargingStation"
    },
    "createRequest": {
      "$ref": "#/$defs/StationCreationRequest"
    },
    "updateRequest": {
      "$ref": "#/$defs/StationUpdateRequest"
    },
    "detailResponse": {
      "$ref": "#/$defs/StationDetailResponse"
    },
    "businessListItem": {
      "$ref": "#/$defs/BusinessStationListItem"
    }
  },
  "examples": [
    {
      "station": {
        "id": "CS_HCM_Q1_001",
        "name": "Tram sac EV Le Loi",
        "manufacturerId": "CPO001",
        "manufacturerName": "EVN Charging",
        "position": {
          "longitude": 106.70098,
          "latitude": 10.77689
        },
        "address": "123 Le Loi",
        "district": "Quan 1",
        "status": 1,
        "images": [
          {
            "key": "CS_HCM_Q1_001-front.jpg",
            "url": "https://cdn.evcharging.local/stations/CS_HCM_Q1_001-front.jpg",
            "type": "image/jpeg"
          }
        ],
        "chargingPoints": [
          {
            "id": "CP001",
            "status": 1,
            "connectors": [
              {
                "id": "CON001",
                "type": 0,
                "price": 3200,
                "voltage": 400,
                "maxPower": 120,
                "isAvailable": true
              },
              {
                "id": "CON002",
                "type": 1,
                "price": 2800,
                "voltage": 230,
                "maxPower": 22,
                "isAvailable": false
              }
            ]
          }
        ]
      }
    }
  ],
  "$defs": {
    "Coordinate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        }
      },
      "required": [
        "longitude",
        "latitude"
      ]
    },
    "StationStatusCode": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "description": "0=UNAVAILABLE, 1=AVAILABLE, 2=BUSY, 3=FULL"
    },
    "ChargingPointStatusCode": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "description": "0=OFFLINE, 1=AVAILABLE, 2=MAINTENANCE, 3=IN_USE"
    },
    "ConnectorTypeCode": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "description": "0=CCS2, 1=TYPE_2, 2=CHAdeMO, 3=TESLA"
    },
    "StationImage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "type": {
          "type": "string",
          "description": "MIME type, e.g. image/png or image/jpeg"
        }
      },
      "required": [
        "key",
        "url"
      ]
    },
    "Connector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "$ref": "#/$defs/ConnectorTypeCode"
        },
        "price": {
          "type": "number",
          "minimum": 0,
          "description": "Charging price (project-specific currency/unit)."
        },
        "voltage": {
          "type": "number",
          "minimum": 0
        },
        "maxPower": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum charging power."
        },
        "isAvailable": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "type",
        "isAvailable"
      ]
    },
    "ChargingPoint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/ChargingPointStatusCode"
        },
        "connectors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Connector"
          },
          "default": []
        }
      },
      "required": [
        "id",
        "status"
      ]
    },
    "BusinessChargingStation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "manufacturerId": {
          "type": "string",
          "minLength": 1,
          "description": "Enterprise/CPO identifier."
        },
        "manufacturerName": {
          "type": "string",
          "description": "Enterprise display name."
        },
        "position": {
          "$ref": "#/$defs/Coordinate"
        },
        "address": {
          "type": "string",
          "minLength": 1
        },
        "district": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/StationStatusCode"
        },
        "numberOfSaves": {
          "type": "integer",
          "minimum": 0
        },
        "hitFullCount": {
          "type": "integer",
          "minimum": 0
        },
        "capacity": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of vehicles station can handle."
        },
        "currentVehicleCount": {
          "type": "integer",
          "minimum": 0
        },
        "images": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StationImage"
          },
          "default": []
        },
        "chargingPoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ChargingPoint"
          },
          "default": []
        }
      },
      "required": [
        "id",
        "name",
        "position",
        "address",
        "district",
        "status"
      ]
    },
    "StationCreationRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "position": {
          "$ref": "#/$defs/Coordinate"
        },
        "address": {
          "type": "string",
          "minLength": 1
        },
        "district": {
          "type": "string",
          "minLength": 1
        },
        "chargingPoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ChargingPoint"
          },
          "default": []
        }
      },
      "required": [
        "id",
        "name",
        "position",
        "address",
        "district"
      ]
    },
    "StationUpdateRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "position": {
          "$ref": "#/$defs/Coordinate"
        },
        "address": {
          "type": "string",
          "minLength": 1
        },
        "district": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "name",
        "position",
        "address",
        "district"
      ]
    },
    "StationDetailResponse": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "manufacturer": {
          "type": "string"
        },
        "position": {
          "$ref": "#/$defs/Coordinate"
        },
        "address": {
          "type": "string",
          "minLength": 1
        },
        "district": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/StationStatusCode"
        },
        "images": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StationImage"
          },
          "default": []
        },
        "connectors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Connector"
          },
          "default": []
        }
      },
      "required": [
        "id",
        "name",
        "manufacturer",
        "position",
        "address",
        "district",
        "status",
        "images",
        "connectors"
      ]
    },
    "BusinessStationListItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "address": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/StationStatusCode"
        },
        "numberOfChargingPoints": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "id",
        "name",
        "address",
        "status"
      ]
    }
  }
}
